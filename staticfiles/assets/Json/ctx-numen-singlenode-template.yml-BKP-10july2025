  #       - Key: "Name"
  #         Value: !Ref ResId
  #     LustreConfiguration:
  #       DeploymentType: !Ref fsxDeploymentType
  #       ImportPath: !Sub 's3://${fsxImportBucket}/${fsxImportBucketPrefix}'

Outputs:
  NumenInstanceId:
    Description: The EC2 Instance ID
    Value: !Ref NumenInstance
