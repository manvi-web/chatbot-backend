{%- if env['efshomefsid'] is defined %}
SharedStorage:
{%- endif %}
{%- if env['efshomefsid'] is defined %}
  - MountDir: {{ env['efshomeshareddir'] }}
    Name: EFSHOME
    StorageType: Efs
    EfsSettings:
      FileSystemId: {{ env['efshomefsid'] }}
{%- endif %}
{%- if env['ondemandFSXfsid'] is defined %}
  - MountDir: {{ env['ondemandFSXmountdir'] }}
    Name: ondemandFSX
    StorageType: FsxLustre
    FsxLustreSettings:
      FileSystemId: {{ env['ondemandFSXfsid'] }}
{%- endif %}
