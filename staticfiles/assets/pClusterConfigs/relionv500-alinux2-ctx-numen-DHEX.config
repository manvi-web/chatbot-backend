    Value: s1

  
HeadNode:
  InstanceType: g5.xlarge 
  Networking:
    SubnetId: subnet-00648988ac513833e
    AdditionalSecurityGroups:
      -  sg-04573f63cff33669a
  Ssh:
    KeyName: numen-test-demo  
    AllowedIps: 0.0.0.0/32
  LocalStorage:
    RootVolume:
      Size: 128 
  Dcv:
    Enabled:  true  
    Port: 8443
    AllowedIps: 0.0.0.0/32
  CustomActions:
    OnNodeStart:
      Script: s3://numen-demo-pk1-numenresourcebucket-gmmrta9akemj/parallelcluster-relionv500-alinux2-ctx-numen-DHEX/preinstall/preinstall.sh
      Args: 
        - ' '
    OnNodeConfigured:
      Script: s3://numen-demo-pk1-numenresourcebucket-gmmrta9akemj/parallelcluster-relionv500-alinux2-ctx-numen-DHEX/postinstall/postinstall.sh
      Args: 
        -  'relionv500'
  Iam:
    InstanceRole: arn:aws:iam::851725171780:role/numen-test-webapprole
Scheduling:
  Scheduler: slurm
  SlurmSettings:
    ScaledownIdletime: 30
    EnableMemoryBasedScheduling: true
  SlurmQueues:
     
    
    
    
    
SharedStorage:
  - MountDir: /efshome
    Name: EFSHOME
    StorageType: Efs
    EfsSettings:
      FileSystemId: fs-097c1f9319d604564