    Value: Numen
  - Key:  CREATEDBY
    Value: user@numen.local
  - Key:  RESOURCEBUCKET
    Value: numen-demo-pk1-numenresourcebucket-gmmrta9akemj
  - Key:  SlurmQueuesTitle
    Value: 
  - Key: InstanceType
    Value: g5.xlarge
  - Key: EBSSize
    Value: EBS:128
  - Key: CUSTOMNAME
