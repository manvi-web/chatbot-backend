Region: us-east-1 
Image:
  CustomAmi: ami-06f59d3265152378c 
  Os: alinux2 
CustomS3Bucket: numen-demo-pk1-numenresourcebucket-gmmrta9akemj
Iam:
  Roles:
    LambdaFunctionsRole: arn:aws:iam::851725171780:role/numen-test-webapprole 
Tags:
